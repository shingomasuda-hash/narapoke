# =====================================================================
# なら和ポケ日和  環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください。
# NEXT_PUBLIC_ で始まる変数はブラウザに公開されます。秘密情報は絶対に入れないこと。
# =====================================================================

# アプリのURL（本番は https://... 、ローカルは http://localhost:3000）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase --------------------------------------------------------
# 未設定でも「開発モード」でUI確認は可能です（本番では必ず設定）。
NEXT_PUBLIC_SUPABASE_URL=
# 新形式(sb_publishable_...)・旧形式(eyJ... JWT)どちらも設定可。
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 新形式(sb_secret_...)・旧形式(eyJ... JWT)どちらも設定可。秘密情報。NEXT_PUBLIC を付けない。サーバー処理専用。
SUPABASE_SERVICE_ROLE_KEY=

# ---- LINE ------------------------------------------------------------
# LIFF ID はブラウザで使うため NEXT_PUBLIC。
NEXT_PUBLIC_LIFF_ID=
# 以下はすべてサーバー専用（クライアントへ公開しない）。
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# 店舗スタッフへの通知先（ユーザーID or グループID）。
LINE_STAFF_DESTINATION_ID=
# LINE 実送信の有効化フラグ。false の間はコンソール出力のモック送信。
LINE_INTEGRATION_ENABLED=false

# ---- メール（Resend） -------------------------------------------------
# 未設定の間はコンソール出力のモック送信（実送信しない）。
RESEND_API_KEY=
# 送信元（例: "なら和ポケ日和 <no-reply@yourdomain.com>"）。Resendでドメイン認証が必要。
RESEND_FROM_EMAIL=

# ---- Cron / 各種 -----------------------------------------------------
# リマインドCronの認証シークレット（十分に長いランダム文字列）。
CRON_SECRET=
# テイクアウト税率(%)。未設定なら店舗設定(store_settings)の値を使用。
TAKEOUT_TAX_RATE=10
# 予約可能日数（当日から何日先まで）。
RESERVATION_MAX_DAYS=60
